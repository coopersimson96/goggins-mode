#!/bin/sh
# Workout Gate launcher: `./workout` opens the dashboard, `./workout stats` etc.
# Works from a dev checkout (.venv) or from the plugin cache (runtime venv).
cd "$(dirname "$0")"
PY=".venv/bin/python"
[ -x "$PY" ] || PY="$HOME/.workout-gate/venv/bin/python"
exec "$PY" -m workout_gate "$@"
